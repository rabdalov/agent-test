# BASE SETTINGS
# Уровень логирования приложения (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# TELEGRAM SETTINGS 
# Токен бота Telegram (получается у @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
# ID администратора бота
ADMIN_ID=123456789
# Список разрешённых Telegram ID (через запятую в JSON-формате)
TLG_ALLOWED_ID=[123456789,987654321]

# TRACKS STORAGE SETTINGS
# Базовая директория для хранения треков
TRACKS_ROOT_DIR=/tracks

# OPENROUTER SETTINGS
# Ключ и параметры OpenRouter (заполняются по необходимости)
OPENROUTER_API=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3.5-397b-a17b
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
#OPENROUTER_API=https://routerai.ru/api/v1
#OPENROUTER_MODEL=deepseek/deepseek-v3.2
#OPENROUTER_API_KEY=YOUR_ROUTER_AI_API_KEY_HERE
# DEMUCS SETTINGS
TRACKS_ROOT_DIR="I:\karaoke\music"
DEMUCS_MODEL="htdemucs"
DEMUCS_OUTPUT_FORMAT = "mp3"
# GENIUS SETTINGS
# Токен Genius API для автоматического поиска текста песен (опционально)
# Получить токен: https://genius.com/api-clients
GENIUS_TOKEN=

# YANDEX MUSIC SETTINGS
# Токен Яндекс Музыки для скачивания треков и получения текста песен (опционально)
# Без токена доступ ограничен; получить токен можно через web-интерфейс Яндекс Музыки
YANDEX_MUSIC_TOKEN=

# YOUTUBE DOWNLOAD SETTINGS
# Качество скачиваемого аудио с YouTube (например, "best", "worst", "192")
# По умолчанию "best" – наилучшее доступное качество
YOUTUBE_DOWNLOAD_QUALITY=best

# Lyrics providers feature flags (true/false)
LYRICS_ENABLE_GENIUS=false
# LyricaV2: self-hosted HTTP lyrics service (https://github.com/Wilooper/LyricaV2)
# Set LYRICS_ENABLE_LYRICA=true and configure the base URL below to enable
LYRICS_ENABLE_LYRICA=true
# Base URL of the running LyricaV2 service (no trailing slash)
LYRICA_BASE_URL=https://test-0k.onrender.com #http://localhost:5000
LYRICS_ENABLE_LYRICSLIB=false

# SPEECHES SETTINGS
SPEECHES_BASE_URL="http://192.168.0.206:8001"
TRANSCRIPTION_MODEL_ID="Systran/faster-whisper-medium"
LANG_DEFAULT="ru"
PROMPT_SPEECHES=""
SPEECHES_TIMEOUT=300

ALIGN_ENABLE_FORCED=false

# ALIGN TIMING CORRECTION SETTINGS (ALIGN step)
# Maximum allowed duration (seconds) for the first word of a segment/line.
# If the first word's duration exceeds this threshold, a "(проигрыш)" gap
# marker is inserted before it and the word's start_time is recalculated.
MAX_WORD_TIME=5.0
# Expected/normal duration (seconds) of the first word in a line.
# Used to compute the corrected start_time: start_time = end_time - NORMAL_WORD_TIME
NORMAL_WORD_TIME=1.5

# ASS SUBTITLE SETTINGS
# Font size for karaoke subtitles (pixels, default 60)
ASS_FONT_SIZE=60
# Seconds before the first word to start showing the active line (lead-in preview, default 0.5)
ASS_PREVIEW_OFFSET=0.5

# VIDEO RENDER SETTINGS (RENDER_VIDEO step, ffmpeg)
# Output video resolution (default 1280x720)
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
# Background colour for the karaoke canvas (ffmpeg colour name or hex, default black)
VIDEO_BACKGROUND_COLOR=black
# ffmpeg libx264 preset (ultrafast/superfast/veryfast/faster/fast/medium, default fast)
VIDEO_FFMPEG_PRESET=fast
# ffmpeg CRF quality (0–51, lower = better quality/larger file, default 22)
VIDEO_FFMPEG_CRF=22

# SEND VIDEO TO USER SETTINGS
# Whether to send the final video to the user via Telegram after processing
# If true, video is sent to user; if false, video is not sent but remains available locally
SEND_VIDEO_TO_USER=true

# AUDIO MIX SETTINGS (RENDER_VIDEO step)
# Volume level for voice track when mixing instrumental + voice (as decimal: 0.4 = 40%)
AUDIO_MIX_VOICE_VOLUME=0.4

# DETECT_CHORUS STEP SETTINGS
# Enable/disable the DETECT_CHORUS step entirely (default: true)
# When enabled, chorus segments are detected and saved to volume_segments_file
# When disabled, DETECT_CHORUS step is skipped (MIX_AUDIO step will also be skipped if volume_segments_file is absent)
DETECT_CHORUS_ENABLED=true

# MIX_AUDIO STEP SETTINGS (back-vocal effect)
# Enable/disable the MIX_AUDIO step entirely (default: true)
# When enabled, a back-vocal effect is applied: vocal volume is reduced outside choruses
# and set to CHORUS_BACKVOCAL_VOLUME in chorus segments
MIX_AUDIO_ENABLED=true
# Volume of vocal in chorus segments for back-vocal effect (0.0–1.0, default: 0.3 = 30%)
# In chorus segments, vocal is mixed at this volume level
CHORUS_BACKVOCAL_VOLUME=0.3
# Enable reverb effect on vocal (placeholder for future implementation, default: false)
VOCAL_REVERB_ENABLED=false
# Enable echo effect on vocal (placeholder for future implementation, default: false)
VOCAL_ECHO_ENABLED=false

# CHORUS DETECTOR SETTINGS (DETECT_CHORUS step)
# Minimum duration (seconds) for a segment candidate (default: 5.0)
CHORUS_MIN_DURATION_SEC=5.0
# Threshold of vocal energy below which a segment is classified as "instrumental" (default: 0.05)
# Range: 0.0–1.0; lower value = more segments classified as instrumental
CHORUS_VOCAL_SILENCE_THRESHOLD=0.05
# Tolerance (seconds) when merging boundaries from two files (default: 2.0)
# Boundaries closer than this value are merged into one
CHORUS_BOUNDARY_MERGE_TOLERANCE_SEC=2.0
# CONTENT EXTERNAL URL SETTINGS (RENDER_VIDEO step)
# Base URL of the content server for download links (e.g., content.homeserver.top)
# If set, a download link will be generated after video rendering
# Format: https://{CONTENT_EXTERNAL_URL}/music?getfile={track_stem}/{output_file}
CONTENT_EXTERNAL_URL=https://www.exapmle.com/music

# CORRECT TRANSCRIPT SETTINGS
# Enable/disable the CORRECT_TRANSCRIPT step (uses LLM to correct transcription)
# If true, transcription is corrected using LLM before ALIGN step
# If false, CORRECT_TRANSCRIPT step is skipped
CORRECT_TRANSCRIPT_ENABLED=true

# HOT-RELOAD SETTINGS
# Enable/disable hot-reload of .env configuration without bot restart (default: true)
# When enabled, the bot monitors .env for changes and applies them without restart
ENV_RELOAD_ENABLED=true
# Interval in seconds between .env modification checks (default: 30)
ENV_RELOAD_INTERVAL_SEC=30

# TRACK VISUALIZATION SETTINGS
# Enable/disable PNG timeline visualization after GENERATE_ASS step (default: false)
TRACK_VISUALIZATION_ENABLED=false
