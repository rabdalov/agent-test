# BASE SETTINGS
# Уровень логирования приложения (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# TELEGRAM SETTINGS 
# Токен бота Telegram (получается у @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
# ID администратора бота
ADMIN_ID=123456789
# Список разрешённых Telegram ID (через запятую в JSON-формате)
TLG_ALLOWED_ID=[123456789,987654321]

# TRACKS STORAGE SETTINGS
# Базовая директория для хранения треков
TRACKS_ROOT_DIR=/tracks

# OPENROUTER SETTINGS
# Ключ и параметры OpenRouter (заполняются по необходимости)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_API=https://api.openrouter.ai/v1

# DEMUCS SETTINGS
TRACKS_ROOT_DIR="I:\karaoke\music"
DEMUCS_MODEL="htdemucs"
DEMUCS_OUTPUT_FORMAT = "mp3"
# GENIUS SETTINGS
# Токен Genius API для автоматического поиска текста песен (опционально)
# Получить токен: https://genius.com/api-clients
GENIUS_TOKEN=

# Lyrics providers feature flags (true/false)
LYRICS_ENABLE_GENIUS=false
# LyricaV2: self-hosted HTTP lyrics service (https://github.com/Wilooper/LyricaV2)
# Set LYRICS_ENABLE_LYRICA=true and configure the base URL below to enable
LYRICS_ENABLE_LYRICA=true
# Base URL of the running LyricaV2 service (no trailing slash)
LYRICA_BASE_URL=https://test-0k.onrender.com #http://localhost:5000
LYRICS_ENABLE_LYRICSLIB=false

# SPEECHES SETTINGS
SPEECHES_BASE_URL="http://192.168.0.206:8001"
TRANSCRIPTION_MODEL_ID="Systran/faster-whisper-medium"
LANG_DEFAULT="ru"
PROMPT_SPEECHES=""
SPEECHES_TIMEOUT=300

ALIGN_ENABLE_FORCED=false

# ASS SUBTITLE SETTINGS
# Font size for karaoke subtitles (pixels, default 60)
ASS_FONT_SIZE=60

# VIDEO RENDER SETTINGS (RENDER_VIDEO step, ffmpeg)
# Output video resolution (default 1280x720)
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
# Background colour for the karaoke canvas (ffmpeg colour name or hex, default black)
VIDEO_BACKGROUND_COLOR=black
# ffmpeg libx264 preset (ultrafast/superfast/veryfast/faster/fast/medium, default fast)
VIDEO_FFMPEG_PRESET=fast
# ffmpeg CRF quality (0–51, lower = better quality/larger file, default 22)
VIDEO_FFMPEG_CRF=22
